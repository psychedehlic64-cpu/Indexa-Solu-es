---
interface Props {
  compact?: boolean;
  variant?: "dark" | "light";
}

const { compact = false, variant = "dark" } = Astro.props;
---

<a class={`brand-logo brand-logo--${variant}`} href="/" aria-label="Indexa Soluções">
  <svg class="brand-logo__mark" width="46" height="46" viewBox="0 0 46 46" role="img" aria-label="Símbolo IS da Indexa Soluções">
    <defs>
      <linearGradient id="indexa-is-gradient" x1="10" y1="36" x2="36" y2="10" gradientUnits="userSpaceOnUse">
        <stop stop-color="#0F8C7F" />
        <stop offset="0.5" stop-color="#D4B36A" />
        <stop offset="1" stop-color="#F2E7CF" />
      </linearGradient>
    </defs>
    <rect x="3.5" y="3.5" width="39" height="39" rx="12" fill="currentColor" opacity="0.08" />
    <path d="M13.6 33V13h4.6v20h-4.6Z" fill="currentColor" />
    <path d="M23 27.1c1.4 1.3 3.5 2.1 5.8 2.1 2.1 0 3.2-.7 3.2-1.9 0-1.3-1.2-1.7-3.9-2.3-3.7-.8-7.4-2.1-7.4-6.3 0-3.8 3.1-6.1 8-6.1 3 0 5.7.8 7.8 2.5l-2.4 3.6c-1.5-1.2-3.4-1.8-5.3-1.8-1.9 0-2.8.7-2.8 1.7 0 1.2 1.2 1.6 4 2.2 4.2.9 7.4 2.3 7.4 6.4 0 4-3.2 6.4-8.5 6.4-3.5 0-6.6-1-8.7-3l2.8-3.5Z" fill="url(#indexa-is-gradient)" />
    <path d="M10.8 36.2c7.6 3.4 18.6 2.4 25.1-4.3" fill="none" stroke="url(#indexa-is-gradient)" stroke-width="2" stroke-linecap="round" />
    <circle cx="35.8" cy="10.8" r="2.3" fill="#F2E7CF" />
  </svg>
  {!compact && (
    <span class="brand-logo__text">
      <strong>Indexa</strong>
      <span>Soluções</span>
    </span>
  )}
</a>
