---
import BrandLogo from "./BrandLogo.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const clientAreaHref = `${basePath}area-do-cliente`;

const icons = {
  app: "M8 2.5h8A2.5 2.5 0 0 1 18.5 5v14A2.5 2.5 0 0 1 16 21.5H8A2.5 2.5 0 0 1 5.5 19V5A2.5 2.5 0 0 1 8 2.5Zm2 15h4",
  website: "M3 5.5h18v13H3v-13Zm0 4h18M8 5.5v13",
  map: "M12 21s6-4.4 6-10a6 6 0 0 0-12 0c0 5.6 6 10 6 10Zm0-7.8a2.2 2.2 0 1 0 0-4.4 2.2 2.2 0 0 0 0 4.4Z",
  bot: "M7 9h10a3 3 0 0 1 3 3v4a3 3 0 0 1-3 3H9l-4 2v-2a3 3 0 0 1-3-3v-4a3 3 0 0 1 3-3h2Zm2-4 3 3 3-3M9.5 14h.1M14.5 14h.1",
  automation: "M4 12a8 8 0 0 1 13.7-5.6M20 12a8 8 0 0 1-13.7 5.6M18 4v4h-4M6 20v-4h4",
  diagnostic: "M4 19.5V4.5h16v15H4Zm4-10h8M8 13h5M8 16h8M16.5 7.5l1 1 2-2",
  consulting: "M4 20v-1.5a4.5 4.5 0 0 1 9 0V20M8.5 11a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Zm8.5 0 3 3m0-3-3 3",
  training: "M3.5 6.5 12 3l8.5 3.5L12 10 3.5 6.5Zm3 3V15c0 1.7 2.5 3 5.5 3s5.5-1.3 5.5-3V9.5",
  framework: "M4 7.5 12 3l8 4.5v9L12 21l-8-4.5v-9Zm8-4.5v18M4 7.5l8 4.5 8-4.5",
  software: "M4 5h16v14H4V5Zm3 4h4M7 13h10M7 16h7",
  device: "M7 3.5h10A1.5 1.5 0 0 1 18.5 5v14A1.5 1.5 0 0 1 17 20.5H7A1.5 1.5 0 0 1 5.5 19V5A1.5 1.5 0 0 1 7 3.5Zm3 14h4",
  os: "M4 5.5h16v13H4v-13Zm0 9h16M9 21h6",
  seo: "M10.5 18a7.5 7.5 0 1 1 5.3-2.2L21 21l-2 0-4.6-4.6A7.4 7.4 0 0 1 10.5 18Zm-3-7.5 2 2 4-4",
  portfolio: "M4 7h16v12H4V7Zm4 0V5h8v2M8 12h8"
};

const navItems = [
  {
    href: "#servicos",
    label: "Soluções",
    children: [
      { label: "Aplicativos", icon: icons.app },
      { label: "Websites", icon: icons.website },
      { label: "Google Meu Negócio", icon: icons.map },
      { label: "Chat Bots", icon: icons.bot },
      { label: "Automações de Tarefas", icon: icons.automation },
      { label: "Diagnósticos", icon: icons.diagnostic },
      { label: "Consultoria Presencial", icon: icons.consulting },
      { label: "Treinamento Empresarial", icon: icons.training }
    ]
  },
  {
    href: "#tecnologia",
    label: "Tecnologias",
    children: [
      { label: "Frameworks", icon: icons.framework },
      { label: "Softwares", icon: icons.software },
      { label: "Dispositivos", icon: icons.device },
      { label: "Sistemas Operacionais", icon: icons.os },
      { label: "CEO", icon: icons.seo }
    ]
  },
  { href: "#clientes", label: "Clientes" },
  {
    href: "#portfolio",
    label: "Portifólio",
    children: [
      { label: "Aplicativos", icon: icons.app },
      { label: "Websites", icon: icons.website },
      { label: "Chat Bots", icon: icons.bot },
      { label: "Google Meu Negócio", icon: icons.map },
      { label: "Automações de Tarefas", icon: icons.automation }
    ]
  },
  { href: "#contato", label: "Contato" }
];
---

<header class="site-header" data-site-header>
  <div class="container site-header__inner">
    <BrandLogo variant="light" />
    <button class="mobile-menu-button" type="button" aria-label="Abrir menu" aria-expanded="false" data-mobile-menu-button>
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="site-nav" aria-label="Navegação principal">
      {navItems.map((item) => (
        <div class:list={["site-nav__item", item.children && "site-nav__item--has-menu"]}>
          {item.children ? (
            <>
              <a class="site-nav__link site-nav__link--desktop" href={item.href}>
                <span>{item.label}</span>
                <i aria-hidden="true"></i>
              </a>
              <button class="site-nav__link site-nav__toggle" type="button" aria-expanded="false">
                <span>{item.label}</span>
                <i aria-hidden="true"></i>
              </button>
            </>
          ) : (
            <a class="site-nav__link" href={item.href}>
              <span>{item.label}</span>
            </a>
          )}
          {item.children && (
            <div class="site-nav__panel">
              <div class="site-nav__panel-head">
                <span>{item.label}</span>
                <strong>Atuação sob medida</strong>
              </div>
              <div class="site-nav__panel-grid">
                {item.children.map((child) => (
                  <a href={item.href}>
                    <span class="site-nav__panel-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24">
                        <path d={child.icon}></path>
                      </svg>
                    </span>
                    <span>{child.label}</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
      <a class="client-area-button client-area-button--mobile" href={clientAreaHref} aria-label="Acessar area do cliente">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3.5 19 6v5.2c0 4.3-2.8 8-7 9.3-4.2-1.3-7-5-7-9.3V6l7-2.5Z"></path>
          <path d="M9.5 12.2 11.2 14l3.6-4"></path>
        </svg>
        <span>Área do Cliente</span>
      </a>
    </nav>
    <a class="client-area-button" href={clientAreaHref} aria-label="Acessar area do cliente">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 3.5 19 6v5.2c0 4.3-2.8 8-7 9.3-4.2-1.3-7-5-7-9.3V6l7-2.5Z"></path>
        <path d="M9.5 12.2 11.2 14l3.6-4"></path>
      </svg>
      <span>Área do Cliente</span>
    </a>
  </div>
</header>

<script>
  const header = document.querySelector("[data-site-header]");
  const mobileMenuButton = document.querySelector("[data-mobile-menu-button]");
  const mobileSubmenuToggles = header?.querySelectorAll(".site-nav__toggle");

  function updateHeaderState() {
    header?.classList.toggle("is-scrolled", window.scrollY > 12);
  }

  function closeMobileMenu() {
    header?.classList.remove("is-menu-open");
    mobileMenuButton?.setAttribute("aria-expanded", "false");
    mobileMenuButton?.setAttribute("aria-label", "Abrir menu");
  }

  updateHeaderState();
  window.addEventListener("scroll", updateHeaderState, { passive: true });

  mobileMenuButton?.addEventListener("click", () => {
    const isOpen = header?.classList.toggle("is-menu-open") ?? false;
    mobileMenuButton.setAttribute("aria-expanded", String(isOpen));
    mobileMenuButton.setAttribute("aria-label", isOpen ? "Fechar menu" : "Abrir menu");
  });

  mobileSubmenuToggles?.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const item = toggle.closest(".site-nav__item");
      const isOpen = item?.classList.toggle("is-submenu-open") ?? false;
      toggle.setAttribute("aria-expanded", String(isOpen));
    });
  });

  header?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMobileMenu);
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeMobileMenu();
    }
  });
</script>
