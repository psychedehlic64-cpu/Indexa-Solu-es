---
import BrandLogo from "./BrandLogo.astro";
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <BrandLogo variant="light" />
      <p>Consultoria, tecnologia, automações, sistemas e serviços personalizados para empresas que precisam resolver gargalos com mais clareza.</p>
    </div>
    <div>
      <h2>Atuações</h2>
      <a href="#servicos">Soluções empresariais</a>
      <a href="#tecnologia">Tecnologia e TI</a>
      <a href="#automacoes">IA e automações</a>
      <a href="#processo">Consultoria estratégica</a>
    </div>
    <div>
      <h2>Contato</h2>
      <a href="mailto:contato@indexasolucoes.com.br">contato@indexasolucoes.com.br</a>
      <a href="#contato">WhatsApp a definir</a>
      <span>Joinville, Santa Catarina</span>
    </div>
  </div>
  <div class="container site-footer__bottom">
    <span>© {new Date().getFullYear()} Indexa Soluções. Todos os direitos reservados.</span>
